# ── Required threat-intel API keys ─────────────────────────────────────────
OPENAI_API_KEY=
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=
URLSCAN_API_KEY=

# ── Optional OpenTelemetry configuration ───────────────────────────────────
# Default: spans are exported to a local OTLP collector agent at
# http://localhost:4318 (OTLP/HTTP). Override only if your collector lives
# elsewhere or you want to ship traces to a managed observability backend.
#
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer your_token,x-extra-header=value
# OTEL_SERVICE_NAME=flowrun-streamlet-ioc-triage
